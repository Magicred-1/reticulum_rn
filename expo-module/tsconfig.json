{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {},
    "types": [
      "node",
      "jest"
    ]
  },
  "include": [
    "src/**/*",
    "__tests__/**/*",
    "jest.setup.ts"
  ]
}